// FLEXIBLE NUMBER RESOLUTION
// ============================================================

function resolveHand(handDef, flexType, values) {
  return {
    ...handDef,
    groups: handDef.groups.map(g => {
      if (!g.numberFlex) return g;
      const m = {
        'like':values[0],
        'even':values[0],'even_kong':values[0],
        'odd':values[0],'odd_kong':values[0],
        'odd_float':values[0],'odd_float_kong':values[0],
        'consec2_pos1':values[0],'consec2_pos2':values[1],
        'consec3_pos1':values[0],'consec3_pos2':values[1],'consec3_pos3':values[2],
        'consec4_pos1':values[0],'consec4_pos2':values[1],'consec4_pos3':values[2],'consec4_pos4':values[3],
        'consec5_outer1':values[0],'consec5_inner1':values[1],'consec5_inner2':values[2],
        'consec5_inner3':values[3],'consec5_outer2':values[4],
        'consec7_pos1':values[0],'consec7_pos2':values[1],'consec7_pos3':values[2],
        'consec7_pos4':values[3],'consec7_pos5':values[4],'consec7_pos6':values[5],'consec7_pos7':values[6],
        '369_pair':values[0],'369_kong':values[0],'369_single1':values[1],'369_single2':values[2],
        'tworank_pos1':values[0],'tworank_pos2':values[1],
      };
      const v = m[g.numberFlex];
      return v != null ? {...g, number:v} : g;
    })
  };
}

function suitComboHasConflict(handDef, suitMap) {
  // Check if any number appears in BOTH a single/pair group AND a pung/kong/quint
  // group with the same suit assignment — singles consume tiles the pung needs
  const singlesAndPairs = handDef.groups.filter(g=>
    (g.groupType==='single'||g.groupType==='pair') && g.number && g.suit
  );
  const pungsAndUp = handDef.groups.filter(g=>
    (g.groupType==='pung'||g.groupType==='kong'||g.groupType==='quint') && g.number && g.suit
  );
  for (const s of singlesAndPairs) {
    for (const p of pungsAndUp) {
      if (s.number===p.number && s.suit===p.suit && suitMap[s.suit]===suitMap[p.suit]) {
        // Same number, same suit slot assigned same suit — conflict
        // BUT this is only a problem if it's the same suit (A===A is fine if A and A
        // are intentionally the same suit, like 2026 L4 pair+pung of 2 in Suit A)
        // The real conflict is when the hand INTENDS different suits but got same
        // We rely on the hand definition: if groups have SAME suit letter, they share suit by design
        // If they have DIFFERENT suit letters but map to same suit, that's the conflict
        if (s.suit !== p.suit) return true;
      }
    }
  }
  return false;
}

function findBestScore(handDef, hand) {
  const suitCombos = getSuitCombos(handDef.suitsRequired||0);
  let best = null;

  const tryScore = (def, suitMap) => {
    // Skip combos where different suit slots map to the same suit AND
    // that causes a conflict between singles/pairs and pungs of same number
    if (suitComboHasConflict(def, suitMap)) return;
    const r = scoreHand(def, suitMap, hand);
    if (!r) return;

    // Priority scoring: pairs and singles MUST be filled before considering
    // callable group bonuses. A combo that fills your singles beats one that
    // leaves them empty even if the callable groups score higher.
    //
    // Compute tiles toward pair/single positions (fully matched)
    const priorityTilesFull = r.details.matched
      .filter(m => m.groupType === 'pair' || m.groupType === 'single')
      .reduce((sum, m) => sum + (m.groupType === 'pair' ? 2 : 1), 0);
    // Partial holds toward pair/single positions
    const priorityTilesPartial = r.details.missing
      .filter(m => m.isPairSingle && m.holds > 0)
      .reduce((sum, m) => sum + m.holds, 0);
    const priorityScore = priorityTilesFull * 10 + priorityTilesPartial;

    // Only replace best if this combo fills MORE priority tiles,
    // OR equal priority tiles with a higher final score
    const isBetter = !best
      || priorityScore > (best._priorityScore || 0)
      || (priorityScore === (best._priorityScore || 0) && r.finalScore > best.finalScore);

    if (isBetter) {
      // Save previous best as secondBest before replacing
      if (best && best.suitMap && JSON.stringify(best.suitMap) !== JSON.stringify(suitMap)) {
        best._secondBest = {matched: best.matched, suitMap: best.suitMap};
      }
      best = {...r, handDef, _priorityScore: priorityScore, _secondBest: best?._secondBest||null};
    } else if (best && !best._secondBest && r.finalScore > 0 &&
               JSON.stringify(suitMap) !== JSON.stringify(best.suitMap)) {
      // Track second best different suit assignment
      if (r.matched >= best.matched - 2) {
        best._secondBest = {matched: r.matched, suitMap: {...suitMap}};
      }
    }
  };

  for (const suitMap of suitCombos) {
    const flex = handDef.flexibility;
    if (flex==='any_like_number') {
      for (let n=1;n<=9;n++) tryScore(resolveHand(handDef,'like',[n]), suitMap);
    } else if (flex==='any_consecutive') {
      const rl = Math.min(handDef.runLength||3, 9);
      const maxStart = Math.max(1, 10-rl);
      for (let s=1;s<=maxStart;s++) {
        const nums = Array.from({length:rl},(_,i)=>s+i);
        tryScore(resolveHand(handDef,'consec',nums), suitMap);
      }
    } else if (flex==='any_two_ranks') {
      // Try ALL pairs of distinct ranks (1-9) in the mapped suit.
      // This is specifically for hands like QT_L3 where any two ranks in
      // the same suit are valid — numeric distance is irrelevant.
      // We score all 36 rank-pairs and keep the best fit via tryScore.
      const suit = suitMap['A'];
      for (let a=1;a<=9;a++) {
        for (let b=a+1;b<=9;b++) {
          tryScore(resolveHand(handDef,'tworank',[a,b]), suitMap);
        }
      }
    } else if (flex==='any_even_number'||flex==='any_even_kong') {
      for (const n of [2,4,6,8]) tryScore(resolveHand(handDef,'even',[n]), suitMap);
    } else if (flex==='any_odd_number') {
      for (const n of [1,3,5,7,9]) tryScore(resolveHand(handDef,'odd',[n]), suitMap);
    } else if (flex==='369_block') {
      for (const p of [3,6,9]) {
        const s=[3,6,9].filter(x=>x!==p);
        tryScore(resolveHand(handDef,'369block',[p,s[0],s[1]]), suitMap);
      }
    } else if (flex==='floating_pair_odd') {
      for (const n of [1,3,5,7,9]) tryScore(resolveHand(handDef,'floatpair',[n]), suitMap);
    } else {
      tryScore(handDef, suitMap);
    }
  }
  return best;
}

