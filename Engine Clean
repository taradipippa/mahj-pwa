// ============================================================

const SECTION_SIGNALS = {
  // 2026: need pair of 2s AND a 6 or White Dragon — real foundation
  '2026': h => {
    const has2pair = Object.values({BAM:h.numberCounts[2]?.BAM||0,CRK:h.numberCounts[2]?.CRK||0,DOT:h.numberCounts[2]?.DOT||0}).some(c=>c>=2);
    const has6 = (h.numberCounts[6]?.total||0)>=1;
    const hasWD = h.dragons.WHITE>=1;
    return has2pair && (has6||hasWD);
  },
  // 2468: need at least 3 different even numbers with real tile count
  '2468': h => {
    const evens = [2,4,6,8].filter(n=>(h.numberCounts[n]?.total||0)>=2).length;
    const evensSingle = [2,4,6,8].filter(n=>(h.numberCounts[n]?.total||0)>=1).length;
    return evens>=2 || evensSingle>=4;
  },
  // Any Like Numbers: need 3+ of same number in one suit
  'any_like_numbers': h => {
    // Need 4+ of same number in same suit to be meaningful for ALN hands
    return Object.values(h.numberCounts).some(nc=>
      (nc.BAM||0)>=4 || (nc.CRK||0)>=4 || (nc.DOT||0)>=4
    );
  },
  // Winds & Dragons: need real wind/dragon concentration
  'winds_dragons': h => {
    const windTotal = Object.values(h.winds).reduce((a,b)=>a+b,0);
    const windPairs = Object.values(h.winds).filter(c=>c>=2).length;
    const dragonTotal = Object.values(h.dragons).reduce((a,b)=>a+b,0);
    const dragonPairs = Object.values(h.dragons).filter(c=>c>=2).length;
    // Need meaningful wind/dragon concentration — not just 2 stray dragons
    // dragonPairs = number of dragon TYPES with a pair (max 3)
    // Require: 2+ wind pairs, OR 4+ winds, OR 2+ dragon-type pairs, OR wind pair + dragon pair
    return windPairs>=2 || windTotal>=4 || dragonPairs>=2 || (windPairs>=1 && dragonPairs>=1);
  },
  // 369: need at least 2 of the 3 key numbers with real tiles (not just singles)
  '369': h => {
    const count369 = [3,6,9].filter(n=>(h.numberCounts[n]?.total||0)>=2).length;
    const present369 = [3,6,9].filter(n=>(h.numberCounts[n]?.total||0)>=1).length;
    return count369>=2 || (count369>=1 && present369>=3);
  },
  // Consecutive Run: need 3+ consecutive in same suit with meaningful tiles
  'consecutive_run': h => {
    for (const suit of SUITS) {
      const nums = Object.entries(h.numberCounts)
        .filter(([,nc])=>(nc[suit]||0)>=1)
        .map(([n])=>parseInt(n))
        .sort((a,b)=>a-b);
      let run=1, maxRun=1;
      for (let i=1;i<nums.length;i++) {
        if (nums[i]===nums[i-1]+1) run++;
        else run=1;
        maxRun = Math.max(maxRun, run);
      }
      // Need run of 3 AND at least 4 total suited tiles (real concentration)
      const suitTotal = Object.values(h.numberCounts).reduce((s,nc)=>s+(nc[suit]||0),0);
      if (maxRun>=3 && suitTotal>=4) return true;
    }
    return false;
  },
  // 13579: need 3+ odd numbers with real tiles
  '13579': h => {
    const oddsWithPairs = [1,3,5,7,9].filter(n=>(h.numberCounts[n]?.total||0)>=2).length;
    const oddsPresent = [1,3,5,7,9].filter(n=>(h.numberCounts[n]?.total||0)>=1).length;
    return oddsWithPairs>=2 || oddsPresent>=4;
  },
  // Quints: need 2+ jokers
  'quints': h => h.jokers>=2,
  // Singles & Pairs: need multiple actual pairs of winds or dragons
  'singles_and_pairs': h => {
    // Signal always true — threshold handled by countTilesForSection (6+ tiles)
    return true;
  },
};

const SECTION_REASON = {
  '2026':           h => `Your 2s${h.dragons.WHITE?' and White Dragon':''} point straight here.`,
  '2468':           h => `You're holding ${[2,4,6,8].filter(n=>(h.numberCounts[n]?.total||0)>=1).join(', ')} — even numbers are your base.`,
  'any_like_numbers':h => {
    const best = Object.entries(h.numberCounts).sort((a,b)=>Math.max(b[1].BAM,b[1].CRK,b[1].DOT)-Math.max(a[1].BAM,a[1].CRK,a[1].DOT))[0];
    return best ? `Your concentration of ${best[0]}s across suits makes this worth a look.` : 'You have multiples of the same number across suits.';
  },
  'winds_dragons':  h => {
    const wc = Object.values(h.winds).reduce((a,b)=>a+b,0);
    const dc = Object.values(h.dragons).reduce((a,b)=>a+b,0);
    return `${wc} wind${wc!==1?'s':''} and ${dc} dragon${dc!==1?'s':''} in hand — this section is built for that.`;
  },
  '369':            h => `You're holding ${[3,6,9].filter(n=>(h.numberCounts[n]?.total||0)>=1).join(', ')} — the building blocks of this section.`,
  'consecutive_run':h => `Your tiles run in sequence — Consecutive Run rewards that.`,
  '13579':          h => `You've got ${[1,3,5,7,9].filter(n=>(h.numberCounts[n]?.total||0)>=1).join(', ')} — odd numbers are your strength here.`,
  'quints':         h => `${h.jokers} joker${h.jokers!==1?'s':''} in hand — quints are in play.`,
  'singles_and_pairs': h => `Multiple pairs in hand — Singles & Pairs is worth considering.`,
};

const SECTION_DISPLAY = {
  '2026':'2026','2468':'2468','any_like_numbers':'Any Like Numbers',
  'winds_dragons':'Winds & Dragons','369':'369','consecutive_run':'Consecutive Run',
  '13579':'13579','quints':'Quints','singles_and_pairs':'Singles & Pairs'
};

function countTilesForSection(sectionKey, hand) {
  // Count actual tiles matched (not joker-adjusted) toward any hand in this section
  const handsInSection = HAND_LIBRARY.filter(h => h.section === sectionKey);
  let maxTiles = 0;
  for (const handDef of handsInSection) {
    const result = findBestScore(handDef, hand);
    // Use raw matched count only — not joker-inflated
    if (result && result.matched > maxTiles) maxTiles = result.matched;
  }
  return maxTiles;
}

function getSectionFocus(hand, topSections, displayedHandSections) {
  const SECTION_TILE_THRESHOLD = 6;
  const SP_TILE_THRESHOLD = 9;

  const qualifying = Object.entries(SECTION_SIGNALS)
    .filter(([,fn]) => fn(hand))
    .map(([key]) => {
      const tileCount = countTilesForSection(key, hand);
      const threshold = key === 'singles_and_pairs' ? SP_TILE_THRESHOLD : SECTION_TILE_THRESHOLD;
      return {
        key,
        name: SECTION_DISPLAY[key],
        reason: SECTION_REASON[key](hand),
        priority: topSections && topSections.includes(key) ? 1 : 0,
        tileCount,
        threshold
      };
    })
    .filter(s => s.tileCount >= s.threshold)
    // Fix 6: only show section if at least one displayed hand is in it
    .filter(s => displayedHandSections && displayedHandSections.includes(s.key));

  qualifying.sort((a,b) => b.priority - a.priority || b.tileCount - a.tileCount);
  return qualifying.slice(0, 4);
}

// ============================================================
// DISCARD ANALYSIS
// ============================================================

function getDiscardRecommendations(tiles, top3, pivots, next5, hand) {
  // Tiered discard logic:
  // Tier 1: tiles not used in top3 + next3 + pivots
  // Tier 2: tiles not used in top3 + next3
  // Tier 3: tiles not used in top3 only
  // Tier 4: fallback — everything is used in top 3

  const buildKeepScores = (handList) => {
    const tileScores = {};
    Object.entries(selectedTiles).forEach(([id, count]) => {
      const tile = ALL_TILES[id];
      if (!tile || tile.type === 'JOKER') return;
      let keepScore = 0;
      handList.forEach(({ rec }) => {
        const tileMatchesGroup = (m) => {
          if (tile.type==='FLOWER' && m.tileType==='FLOWER') return true;
          if (tile.type==='NUMBER' && m.tileType==='NUMBER' &&
              m.number===tile.number && m.suit===tile.suit) return true;
          if (tile.type==='WIND' && m.tileType==='WIND') return m.wind === tile.wind;
          if (tile.type==='DRAGON' && m.tileType==='DRAGON') {
            if (m.dragon && m.dragon===tile.dragon) return true;
            const rawSuit = m.suit;
            const recSuit = (rawSuit==='BAM'||rawSuit==='CRK'||rawSuit==='DOT')
              ? rawSuit
              : (rawSuit && rec.suitMap ? rec.suitMap[rawSuit] : null);
            if (recSuit==='BAM' && tile.dragon==='GREEN') return true;
            if (recSuit==='CRK' && tile.dragon==='RED') return true;
            if (recSuit==='DOT' && tile.dragon==='WHITE') return true;
            if (recSuit==='BAM' && (tile.dragon==='RED'||tile.dragon==='WHITE')) return true;
            if (recSuit==='CRK' && (tile.dragon==='GREEN'||tile.dragon==='WHITE')) return true;
            if (recSuit==='DOT' && (tile.dragon==='GREEN'||tile.dragon==='RED')) return true;
            if (!recSuit && !m.dragon && m.holds > 0) return true;
          }
          return false;
        };
        const inMatched = rec.details.matched.some(m => tileMatchesGroup(m));
        const inMissing = rec.details.missing.some(m => tileMatchesGroup(m));
        if (inMatched || inMissing) keepScore += 1;
      });
      tileScores[id] = { tile, keepScore, count };
    });
    return tileScores;
  };

  const formatTileLabel = (tile) => {
    if (tile.type==='NUMBER') return `${tile.number}-${tile.suit[0]}${tile.suit.slice(1).toLowerCase()}`;
    if (tile.type==='WIND') return `${tile.wind[0]}${tile.wind.slice(1).toLowerCase()} Wind`;
    if (tile.type==='DRAGON') return `${tile.dragon[0]}${tile.dragon.slice(1).toLowerCase()} Dragon`;
    if (tile.type==='FLOWER') return 'Flower';
    return '';
  };

  const getCandidates = (handList) => {
    const scores = buildKeepScores(handList);
    return Object.entries(scores)
      .filter(([,v]) => v.keepScore === 0)
      .map(([,{tile}]) => formatTileLabel(tile))
      .filter(Boolean);
  };

  // Tier 1: dead to top3 + next3 + pivots
  const allHands = [
    ...(top3[0] ? [{rec:top3[0]}] : []),
    ...(top3[1] ? [{rec:top3[1]}] : []),
    ...(top3[2] ? [{rec:top3[2]}] : []),
    ...(next5||[]).map(rec=>({rec})),
    ...(pivots||[]).map(rec=>({rec})),
  ];
  let candidates = getCandidates(allHands);
  if (candidates.length > 0) return { tiles: candidates.slice(0,3), tier: 1 };

  // Tier 2: dead to top3 + next3
  const top3AndNext = [
    ...(top3[0] ? [{rec:top3[0]}] : []),
    ...(top3[1] ? [{rec:top3[1]}] : []),
    ...(top3[2] ? [{rec:top3[2]}] : []),
    ...(next5||[]).map(rec=>({rec})),
  ];
  candidates = getCandidates(top3AndNext);
  if (candidates.length > 0) return { tiles: candidates.slice(0,3), tier: 2 };

  // Tier 3: dead to top3 only
  const top3Only = [
    ...(top3[0] ? [{rec:top3[0]}] : []),
    ...(top3[1] ? [{rec:top3[1]}] : []),
    ...(top3[2] ? [{rec:top3[2]}] : []),
  ];
  candidates = getCandidates(top3Only);
  if (candidates.length > 0) return { tiles: candidates.slice(0,3), tier: 3 };

  // Tier 4: everything is used
  return { tiles: [], tier: 4 };
}

