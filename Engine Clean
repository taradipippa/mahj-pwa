function renderHandDisplay(handId, rec) {
  const tokens = HAND_DISPLAY[handId];
  if (!tokens) return '';

  // Determine how many suits this hand uses
  const suitsReq = rec ? (rec.handDef.suitsRequired || 0) : 0;

  // Color palette based on suit count
  // 1 suit: all green
  // 2 suits: green + red
  // 3 suits: green + red + navy
  // Honors (winds, dragons, flowers) always blue
  const suitColors = suitsReq >= 3
    ? {G:'#2d6a3f', R:'#c0392b', N:'#1a1410'}
    : suitsReq === 2
    ? {G:'#2d6a3f', R:'#c0392b', N:'#2d6a3f'}
    : {G:'#2d6a3f', R:'#2d6a3f', N:'#2d6a3f'};

  // Honor tokens (winds, dragons, flowers, soap) always blue
  const honorPattern = /^[NESWDGRF]$|^(NEWS|DDD|DD|GG|RR|WW|EE|SS|NN|FF|FFF|FFFF|FFFFFF|Soap)$/;
  const blueColor = '#1a3060';

  return tokens.map(({t,c}) => {
    if (!t.trim()) return ' ';
    // Detect honor tokens — single letters that are winds/dragons or known honor strings
    // Winds and flowers always blue
    const isAlwaysBlue = /^[NEWSF]+$/.test(t);
    // Dragons show their LITERAL color — not suit-mapped
    const isDragon = /^D+$/.test(t) || t==='Soap';
    // Literal color map (for dragons)
    const literalColors = {'G':'#2d6a3f','R':'#c0392b','N':'#1a1410','':'#1a3060'};
    const color = isAlwaysBlue ? blueColor
                : isDragon     ? (c==='' ? blueColor : (literalColors[c] || blueColor))
                : c===''       ? blueColor
                : (suitColors[c] || suitColors.N);
    return `<span style="color:${color};font-weight:700;letter-spacing:0.5px">${t}</span>`;
  }).join('');
}

