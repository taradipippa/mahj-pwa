// ── Pure logic functions ──
function analyzeHand() {
  const tiles    = [];
  Object.entries(selectedTiles).forEach(([id,count]) => {
    const tile = ALL_TILES[id];
    for (let i=0;i<count;i++) tiles.push(tile);
  });

  const jokers   = tiles.filter(t=>t.type==='JOKER');
  const nonJokers= tiles.filter(t=>t.type!=='JOKER');

  const hand = {
    jokers: jokers.length,
    flowers: nonJokers.filter(t=>t.type==='FLOWER'),
    winds:   {NORTH:0,SOUTH:0,EAST:0,WEST:0},
    dragons: {WHITE:0,GREEN:0,RED:0},
    numberCounts: {},
    suitCounts:   {BAM:0,CRK:0,DOT:0},
    pairs:[],pungs:[],kongs:[],
    dominantSuit: null,
    hasEvenConc: false, hasOddConc: false,
  };

  for (const t of nonJokers) {
    if (t.type==='NUMBER') {
      hand.suitCounts[t.suit]++;
      if (!hand.numberCounts[t.number]) hand.numberCounts[t.number]={total:0,BAM:0,CRK:0,DOT:0};
      hand.numberCounts[t.number].total++;
      hand.numberCounts[t.number][t.suit]++;
    } else if (t.type==='WIND')   hand.winds[t.wind]++;
    else if   (t.type==='DRAGON') hand.dragons[t.dragon]++;
  }

  const maxSuit = Object.entries(hand.suitCounts).sort((a,b)=>b[1]-a[1])[0];
  if (maxSuit[1]>=4) hand.dominantSuit = maxSuit[0];

  // Pairs/pungs/kongs from raw tiles (no joker)
  for (const [num,counts] of Object.entries(hand.numberCounts)) {
    for (const suit of SUITS) {
      const c = counts[suit];
      if (c>=2) hand.pairs.push({type:'NUMBER',number:parseInt(num),suit});
      if (c>=3) hand.pungs.push({type:'NUMBER',number:parseInt(num),suit});
      if (c>=4) hand.kongs.push({type:'NUMBER',number:parseInt(num),suit});
    }
  }
  for (const [wind,c] of Object.entries(hand.winds)) {
    if (c>=2) hand.pairs.push({type:'WIND',wind});
    if (c>=3) hand.pungs.push({type:'WIND',wind});
    if (c>=4) hand.kongs.push({type:'WIND',wind});
  }
  for (const [dragon,c] of Object.entries(hand.dragons)) {
    if (c>=2) hand.pairs.push({type:'DRAGON',dragon});
    if (c>=3) hand.pungs.push({type:'DRAGON',dragon});
    if (c>=4) hand.kongs.push({type:'DRAGON',dragon});
  }

  const nums = Object.keys(hand.numberCounts).map(Number);
  hand.hasEvenConc = nums.filter(n=>n%2===0).length>=3;
  hand.hasOddConc  = nums.filter(n=>n%2!==0).length>=3;

  return hand;
}

// ============================================================
// SCORING ENGINE
// Key principles:
// 1. Groups scored in priority order: pairs first, then singles,
//    then pungs, kongs, quints — tiles consumed as we go
// 2. Jokers NOT committed to any group — they reduce overall
//    difficulty as a flexible asset applied to final score only
// 3. Each tile type is suit-specific — dragons, winds, numbers
//    never pooled across different types
// ============================================================

function getSuitCombos(n) {
  if (n===0) return [{}];
  if (n===1) return SUITS.map(s=>({A:s}));
  if (n===2) {
    const c=[];
    for (const a of SUITS) for (const b of SUITS) if (a!==b) c.push({A:a,B:b});
    return c;
  }
  const c=[];
  for (const a of SUITS) for (const b of SUITS) for (const cc of SUITS)
    if (a!==b && b!==cc && a!==cc) c.push({A:a,B:b,C:cc});
  return c;
}

// Score a single group against a tile pool (tiles consumed in place)
// Returns { matched, needed, penalty, canClaim, dragonNote }

// ============================================================
// SCORING ENGINE — mechanics-only difficulty model
// Difficulty driven by: tiles missing, calling availability, joker eligibility
// No tile-type bias — winds/dragons/numbers treated identically
// Jokers remain a flexible hand-level asset, never assigned to a specific group
// ============================================================

function scoreGroup(g, suit, pool) {
  let holds = 0;

  if (g.tileType==='NUMBER' && g.number!=null) {
    const key = suit ? `${g.number}_${suit}` : null;
    if (key) {
      holds = pool[key] || 0;
    } else {
      holds = Math.max(
        pool[`${g.number}_BAM`]||0,
        pool[`${g.number}_CRK`]||0,
        pool[`${g.number}_DOT`]||0
      );
    }
  } else if (g.tileType==='FLOWER') {
    holds = pool['FLOWER'] || 0;
  } else if (g.tileType==='DRAGON') {
    if (g.dragon) {
      holds = pool[`DRAGON_${g.dragon}`] || 0;
    } else if (g.dragonRequirement==='matching' && suit) {
      holds = pool[`DRAGON_${MATCHING_DRAGON[suit]}`] || 0;
    } else if (g.dragonRequirement==='opposing' && suit) {
      holds = Math.max(0,...OPPOSING_DRAGONS[suit].map(d=>pool[`DRAGON_${d}`]||0));
    } else if (g.dragonRequirement==='any') {
      holds = Math.max(0,...Object.keys(hand_dragons_list).map(d=>pool[`DRAGON_${d}`]||0));
    }
  } else if (g.tileType==='WIND') {
    if (g.wind) {
      holds = pool[`WIND_${g.wind}`] || 0;
    } else if (g.windFlex==='any') {
      holds = Math.max(0,...['NORTH','EAST','WEST','SOUTH'].map(w=>pool[`WIND_${w}`]||0));
    }
  }

  let resolvedDk = null;
  const effective   = Math.min(holds, g.count);
  const stillNeeded = Math.max(0, g.count - effective);

  // Consume tiles from pool
  if (effective > 0) {
    if (g.tileType==='NUMBER' && g.number!=null) {
      const key = suit ? `${g.number}_${suit}` : findBestNumKey(g.number, pool);
      if (key) pool[key] = Math.max(0,(pool[key]||0) - effective);
    } else if (g.tileType==='FLOWER') {
      pool['FLOWER'] = Math.max(0,(pool['FLOWER']||0) - effective);
    } else if (g.tileType==='DRAGON') {
      const dk = resolveDragonKey(g, suit, pool);
      if (dk) pool[dk] = Math.max(0,(pool[dk]||0) - effective);
      resolvedDk = dk;
    } else if (g.tileType==='WIND') {
      const wk = g.wind ? `WIND_${g.wind}` : findBestWindKey(pool);
      if (wk) pool[wk] = Math.max(0,(pool[wk]||0) - effective);
    }
  }

  const canClaim = g.groupType!=='single' && g.groupType!=='pair';

  // DIFFICULTY — mechanics-only, no tile-type weighting
  // Claimable groups: discard calling available, jokers can help
  //   1 missing → nearly callable → low difficulty
  //   2+ missing → needs wall tiles first → moderate
  // Pairs: no calling before Mahjong, no jokers — pure wall draws
  //   0 held → need both tiles naturally → very high difficulty
  //   1 held → need one tile naturally → medium difficulty
  //   complete → zero difficulty
  // Singles: no calling before Mahjong, no jokers — single wall draw needed
  //   difficulty adjusted by structural context in scoreHand
  let difficultyPerTile;
  if (canClaim) {
    difficultyPerTile = stillNeeded === 1 ? 0.6 : 1.0;
  } else if (g.groupType === 'pair') {
    if      (holds === 0) difficultyPerTile = 2.0;
    else if (holds === 1) difficultyPerTile = 1.4;
    else                  difficultyPerTile = 0;
  } else {
    // single — base difficulty; structural context applied in scoreHand loop
    difficultyPerTile = 1.3;
  }

  const penalty = stillNeeded * difficultyPerTile;

  // Dragon notes for UI — unchanged
  let dragonNote = null;
  if (g.tileType==='DRAGON' && g.dragonRequirement==='opposing' && suit && holds===0) {
    const matchD = MATCHING_DRAGON[suit];
    if ((pool[`DRAGON_${matchD}`]||0)>0)
      dragonNote=`You hold ${matchD} Dragon — that MATCHES ${suit}s, not opposes it.`;
  }
  if (g.tileType==='DRAGON' && g.dragonRequirement==='matching' && suit && holds===0) {
    const matchD = MATCHING_DRAGON[suit];
    const wrongD = ['GREEN','RED','WHITE'].find(d=>d!==matchD&&(pool[`DRAGON_${d}`]||0)>0);
    if (wrongD) dragonNote=`You hold ${wrongD} Dragon — wrong color for ${suit}s. Need ${matchD}.`;
  }

  // If no tiles were consumed (holds=0), resolvedDk wasn't set during consumption.
  // Pool is still untouched for this group, so resolve it now.
  if (g.tileType==='DRAGON' && !resolvedDk) {
    resolvedDk = resolveDragonKey(g, suit, pool);
  }
  return { effective, stillNeeded, penalty, canClaim, dragonNote, holds, groupIsClaimable: canClaim, resolvedDk };
}

const hand_dragons_list = {GREEN:1,RED:1,WHITE:1};

function findBestNumKey(number, pool) {
  let best=null, bestVal=-1;
  for (const s of SUITS) {
    const k=`${number}_${s}`;
    if ((pool[k]||0)>bestVal) { bestVal=pool[k]||0; best=k; }
  }
  return best;
}

function resolveDragonKey(g, suit, pool) {
  if (g.dragon) return `DRAGON_${g.dragon}`;
  if (g.dragonRequirement==='matching'&&suit) return `DRAGON_${MATCHING_DRAGON[suit]}`;
  if (g.dragonRequirement==='opposing'&&suit) {
    return `DRAGON_${OPPOSING_DRAGONS[suit].reduce((best,d)=>(pool[`DRAGON_${d}`]||0)>(pool[`DRAGON_${best}`]||0)?d:best,OPPOSING_DRAGONS[suit][0])}`;
  }
  if (g.dragonRequirement==='any') {
    return `DRAGON_${['GREEN','RED','WHITE'].reduce((best,d)=>(pool[`DRAGON_${d}`]||0)>(pool[`DRAGON_${best}`]||0)?d:best,'GREEN')}`;
  }
  return null;
}

function findBestWindKey(pool) {
  return `WIND_${['NORTH','EAST','WEST','SOUTH'].reduce((best,w)=>(pool[`WIND_${w}`]||0)>(pool[`WIND_${best}`]||0)?w:best,'NORTH')}`;
}

function buildPool(hand) {
  const pool = {};
  for (const [num,counts] of Object.entries(hand.numberCounts)) {
    for (const s of SUITS) pool[`${num}_${s}`] = counts[s]||0;
  }
  for (const [w,c] of Object.entries(hand.winds))   pool[`WIND_${w}`]   = c;
  for (const [d,c] of Object.entries(hand.dragons)) pool[`DRAGON_${d}`] = c;
  pool['FLOWER'] = hand.flowers.length;
  return pool;
}

function scoreHand(handDef, suitMap, hand) {
  const pool = buildPool(hand);

  // Groups scored: pairs first (consume tiles before pungs), then singles, then claimable
  const groupOrder = {pair:0, single:1, pung:2, kong:3, quint:4};
  const sorted = [...handDef.groups].sort((a,b)=>(groupOrder[a.groupType]||2)-(groupOrder[b.groupType]||2));

  let matched=0, total=0, penalty=0;
  let readyToCallCount=0, buildThenCallCount=0;
  const details = { matched:[], missing:[], dragonNotes:[], jokerPositions:0 };

  for (const g of sorted) {
    total += g.count;
    const suit = g.suit ? suitMap[g.suit] : null;
    const r    = scoreGroup(g, suit, pool);

    matched += r.effective;
    if (r.dragonNote) details.dragonNotes.push(r.dragonNote);
    if (r.groupIsClaimable) details.jokerPositions++;

    if (r.effective >= g.count) {
      const resolvedDragonKey = g.tileType==='DRAGON' ? (g.dragon || (r.resolvedDk ? r.resolvedDk.replace('DRAGON_','') : null)) : null;
      details.matched.push({label:g.label, groupType:g.groupType, suit, number:g.number, tileType:g.tileType, wind:g.wind||null, dragon:resolvedDragonKey});
    } else {
      // ── Claiming state ──────────────────────────────────────────────
      let claimState = 'mustDraw';
      if (!handDef.concealed && r.groupIsClaimable) {
        const readyNow       = r.holds >= (g.count - 1);
        // Joker check: use ALL jokers — if holds + jokers >= count-1, ready to call
        // Even 0 tiles held + 3 jokers on a kong = ready to call
        const readyWithJoker = !readyNow && hand.jokers > 0 && (r.holds + hand.jokers) >= (g.count - 1);
        if (readyNow)            { claimState = 'readyToCall';     readyToCallCount++; }
        else if (readyWithJoker) { claimState = 'readyWithJoker';  readyToCallCount++; }
        else                     { claimState = 'pullMoreThenCall'; buildThenCallCount++; }
      }

      // ── Per-group penalty ────────────────────────────────────────────
      // Use mechanics-based difficulty from scoreGroup
      // For singles: apply structural context multiplier
      // Singles clearly supporting a run/sequence are less penalized than isolated ones
      let groupPenalty = r.penalty;

      if (g.groupType === 'single' && r.stillNeeded > 0 && g.number != null) {
        // Connected single: another group in this hand requires an adjacent number (±1 or ±2)
        // This signals the single is part of a run or near-sequence pattern
        const adjacentInHand = handDef.groups.some(other =>
          other !== g &&
          other.number != null &&
          Math.abs(other.number - g.number) <= 2
        );
        // Connected: 15% reduction — still harder than claimable, but not isolated
        // Isolated: full base penalty maintained
        const singleContextMult = adjacentInHand ? 0.85 : 1.0;
        groupPenalty = r.stillNeeded * 1.3 * singleContextMult;
      }

      // Claim bonus: reduces penalty for groups that are close to callable
      // readyToCall → significant relief (one discard away)
      // readyWithJoker → meaningful relief (joker enables call — joker is flexible but still a cost)
      // pullMoreThenCall → small relief (claimable eventually, just not yet)
      // mustDraw → no relief
      const claimBonus = claimState==='readyToCall'      ? 0.55
                       : claimState==='readyWithJoker'   ? 0.35
                       : claimState==='pullMoreThenCall'  ? 0.10
                       : 0;

      groupPenalty = groupPenalty * (1 - claimBonus);
      penalty += groupPenalty;

      const stillToDrawBeforeCall = claimState==='pullMoreThenCall'
        ? Math.max(0, (g.count-1) - r.holds - hand.jokers)
        : 0;

      details.missing.push({
        label:       g.label,
        need:        r.stillNeeded,
        holds:       r.holds,
        claimState,
        isPairSingle:!r.groupIsClaimable,
        groupType:   g.groupType,
        stillToDrawBeforeCall,
        suit,
        number:      g.number,
        tileType:    g.tileType,
        wind:        g.wind||null,
        dragon:      g.tileType==='DRAGON' ? (g.dragon || (r.resolvedDk ? r.resolvedDk.replace('DRAGON_','') : null)) : null,
        tileHint:    g.tileType==='DRAGON' ? (g.dragon||'dragon')
                   : g.tileType==='WIND'   ? (g.wind||'wind')
                   : g.number ? String(g.number) : 'tile'
      });
    }
  }

  if (total===0) return null;
  const fitScore = Math.round((matched/total)*100);

  // ── JOKER BONUS — flexible asset, gradient scaling ───────────────
  // Jokers improve overall claimable-group viability — not tied to any one group.
  // Value scales smoothly with hand viability (no cliff effect).
  // Range: 3.0 pts/joker at fit=0 → 7.0 pts/joker at fit=100
  const jokerViabilityScale = 3 + (fitScore / 100) * 4;
  const jokerBonus = hand.jokers * jokerViabilityScale;

  // ── CALL BONUS ────────────────────────────────────────────────────
  const callBonus = readyToCallCount * 4;

  // ── SCATTERED PAIR PENALTY — structural check only ────────────────
  // Only penalizes pairs that are structurally disconnected from the hand.
  // "Disconnected" = pair's number has no adjacent matched group number (±2)
  // Honor pairs (wind/dragon) treated as disconnected outside winds_dragons hands.
  // Does NOT fire when there is claimable structure already matched.
  const matchedClaimable = details.matched.filter(
    m => m.groupType !== 'pair' && m.groupType !== 'single'
  ).length;

  // ── CONCEALED PENALTY ─────────────────────────────────────────────
  let concPenalty = 0;
  if (handDef.concealed) {
    concPenalty = fitScore >= 70 ? 10 : 13;
    // Reduce penalty based on jokers and structural closeness
    const jokerRelief    = hand.jokers * 1.5;
    const structRelief   = (fitScore / 100) * 4;
    concPenalty = Math.max(0, concPenalty - jokerRelief - structRelief);
  }
  if (handDef.section === 'singles_and_pairs') concPenalty += 7;

  // ── RIGIDITY PENALTY — isolated missing singles only ──────────────
  // Singles that are structurally connected (adjacent matched number ±2) are
  // already softened by singleContextMult in the loop above — not penalized again.
  // Only truly isolated missing singles (no nearby matched number) contribute here.
  const isolatedMissingSingles = details.missing.filter(m => {
    if (m.groupType !== 'single') return false;
    if (!m.number) return handDef.section !== 'winds_dragons';
    return !details.matched.some(
      o => o.number != null && Math.abs(o.number - m.number) <= 2
    );
  }).length;

  const rigidityPenalty = isolatedMissingSingles >= 2
    ? (isolatedMissingSingles - 1) * 3
    : 0;

  // ── FINAL SCORE ───────────────────────────────────────────────────
  const finalScore = Math.max(0,
    fitScore
    - Math.round(penalty * 1.8)
    - rigidityPenalty
    + jokerBonus
    + callBonus
    - concPenalty
  );

  return { fitScore, finalScore, penalty: Math.round(penalty * 10) / 10,
           matched, total, details, concPenalty, suitMap, jokerBonus,
           readyToCallCount, buildThenCallCount };
}
