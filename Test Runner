test('Wrong dragon (opposing vs matching) reduces score', () => {
  // If a hand needs a MATCHING dragon for BAM (= GREEN)
  // but player holds RED (opposing), score should be lower
  const withMatchingDragon = runAnalysis([
    'BAM_2','WHITE','BAM_2','BAM_6',
    'GREEN','GREEN','GREEN',
    'CRK_2','CRK_2','CRK_2','CRK_2',
    'RED','RED','RED',
  ]);
  const withWrongDragon = runAnalysis([
    'BAM_2','WHITE','BAM_2','BAM_6',
    'RED','RED','RED',        // RED is opposing for BAM, not matching
    'CRK_2','CRK_2','CRK_2','CRK_2',
    'RED','RED','RED',
  ]);
  const correctScore = withMatchingDragon.allScores.find(s => s.handDef.id === '2026_L2')?.finalScore || 0;
  const wrongScore   = withWrongDragon.allScores.find(s => s.handDef.id === '2026_L2')?.finalScore || 0;
  assert(correctScore > wrongScore,
    `Matching dragon should score higher (${correctScore}) than wrong dragon (${wrongScore})`);
});

