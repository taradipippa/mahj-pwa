test('Discard only considers top 3 hands — not next5 or pivots', () => {
  // Dragons that appear ONLY in next5/pivot hands should still be recommended for discard
  // if they don't support any of the top 3 hands
  // 1B 1B 3B 5C 5C 5C GD RD F F JOKER JOKER JOKER
  const result = runAnalysis([
    'BAM_1','BAM_1','BAM_3',
    'CRK_5','CRK_5','CRK_5',
    'GREEN','RED',
    'FLOWER','FLOWER',
    'JOKER','JOKER','JOKER',
  ]);
  // Check that GREEN and RED are not in top 3 matched groups
  const greenInTop3 = result.top3.some(rec =>
    rec.details.matched.some(m => m.tileType === 'DRAGON' && m.dragon === 'GREEN') ||
    rec.details.missing.some(m => m.holds > 0 && m.tileType === 'DRAGON' && m.dragon === 'GREEN')
  );
  const redInTop3 = result.top3.some(rec =>
    rec.details.matched.some(m => m.tileType === 'DRAGON' && m.dragon === 'RED') ||
    rec.details.missing.some(m => m.holds > 0 && m.tileType === 'DRAGON' && m.dragon === 'RED')
  );
  // If dragons are not in top 3, they should be recommended for discard
  if (!greenInTop3) {
    assertDiscardIncludes(result, 'Green Dragon',
      'Green Dragon not in top 3 hands — should be recommended for discard');
  }
  if (!redInTop3) {
    assertDiscardIncludes(result, 'Red Dragon',
      'Red Dragon not in top 3 hands — should be recommended for discard');
  }
  // Sanity check: jokers never discarded
  assert(!result.discards.includes('Joker'), 'Jokers must never be recommended for discard');
});

test('Joker count included in next 3 hands tile progress', () => {
  // Hand with jokers — the tile count shown for next3 hands should include joker contribution
  // We verify this by checking that findBestScore with jokers scores higher than without
  const withJokers = runAnalysis([
