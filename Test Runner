  assertDiscardExcludes(result, '2-Bam',   'BAM_2 supports top hand — should never be in discards');
  assertDiscardExcludes(result, 'White Dragon', 'WHITE supports top hand — should never be in discards');
  assertDiscardExcludes(result, '2-Crk',   'CRK_2 supports top hand — should never be in discards');
  assertDiscardExcludes(result, '6-Crk',   'CRK_6 supports top hand — should never be in discards');
});

test('Tiles in top hand all have keepScore > 0', () => {
  // Every tile used in the #1 hand should have a keepScore above 0
  // (meaning the discard engine recognizes them as valuable)
  const result = runAnalysis([
    'BAM_2','BAM_2','BAM_2',
    'WHITE','WHITE','WHITE',
    'CRK_2','CRK_2','CRK_2','CRK_2',
    'CRK_6','CRK_6','CRK_6','CRK_6',
  ]);
  // Build the hand weights manually to check keepScores
  const top3 = result.top3;
  const hw = [
    {rec:top3[0],weight:4},{rec:top3[1],weight:2},{rec:top3[2],weight:1},
    ...result.pivots.map(r=>({rec:r,weight:0.5})),
    ...result.next5.map(r=>({rec:r,weight:0.5})),
  ];
  const topHandTileIds = ['BAM_2','WHITE','CRK_2','CRK_6'];
  topHandTileIds.forEach(id => {
    const tile = e.ALL_TILES[id];
    let ks = 0;
    hw.forEach(({rec,weight}) => {
      const inM = rec.details.matched.some(m => {
        if (tile.type==='NUMBER'&&m.tileType==='NUMBER'&&m.number===tile.number&&m.suit===tile.suit) return true;
        if (tile.type==='DRAGON'&&m.tileType==='DRAGON'&&m.dragon===tile.dragon) return true;
        if (tile.type==='WIND'&&m.tileType==='WIND'&&m.wind===tile.wind) return true;
        if (tile.type==='FLOWER'&&m.tileType==='FLOWER') return true;
        return false;
      });
      const inMs = rec.details.missing.some(m => {
        if (m.holds===0) return false;
        if (tile.type==='NUMBER'&&m.tileType==='NUMBER'&&m.number===tile.number&&m.suit===tile.suit) return true;
        if (tile.type==='DRAGON'&&m.tileType==='DRAGON'&&m.dragon===tile.dragon) return true;
        if (tile.type==='WIND'&&m.tileType==='WIND'&&m.wind===tile.wind) return true;
        if (tile.type==='FLOWER'&&m.tileType==='FLOWER') return true;
        return false;
      });
      if (inM||inMs) ks+=weight;
    });
    assert(ks > 0, id + ' is in the top hand but has keepScore=0 — discard logic bug!');
  });
});

test('Tile only used in pivot hand is NOT recommended when dead tile exists', () => {
  // If a true dead tile (keepScore=0) exists, it should be recommended over
  // a tile that supports a pivot hand (keepScore=0.5).
  // Hand: near-complete 2026_L1, plus a FLOWER (feeds pivot/other hands), plus a dead SOUTH wind
  const result = runAnalysis([
    'BAM_2','BAM_2','BAM_2',
    'WHITE','WHITE','WHITE',
    'CRK_2','CRK_2','CRK_2','CRK_2',
    'CRK_6','CRK_6','FLOWER','SOUTH',
  ]);
  // SOUTH wind is very unlikely to feed top hands — check if it's recommended
  // FLOWER feeds many hands — its keepScore should be >= SOUTH's keepScore
  // So SOUTH should be discarded before FLOWER if SOUTH is truly dead
  const southInDiscards = result.discards.includes('South Wind');
  const flowerInDiscards = result.discards.includes('Flower');
  // If both are equally dead, that's OK — if FLOWER has higher keepScore than SOUTH, SOUTH leads
  assert(southInDiscards || !flowerInDiscards || result.discards.length === 0,
    'If SOUTH is dead weight, it should be discarded before or alongside FLOWER');
});

