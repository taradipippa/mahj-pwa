test('Tiles with keepScore=0 are recommended when they exist', () => {
  // A tile is only recommended if it supports NO ranked hand at all (keepScore=0).
  // The HAND_LIBRARY is broad enough that most tiles support something.
  // This test verifies: if discards ARE recommended, they must have keepScore=0.
  const result = runAnalysis([
    'BAM_2','BAM_2','BAM_2',
    'WHITE','WHITE','WHITE',
    'CRK_2','CRK_2','CRK_2','CRK_2',
